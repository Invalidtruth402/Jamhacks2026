from ultralytics import YOLO
import cv2
import numpy as np
from collections import deque, Counter
import time

model = YOLO("runs/classify/train-10/weights/best.pt")

cap = cv2.VideoCapture(1)

cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)

history = deque(maxlen=15)
conf_history = deque(maxlen=15)

prev_time = time.time()

while True:
    ret, frame = cap.read()
    if not ret:
        break

    input_frame = cv2.resize(frame, (320, 320))

    results = model(input_frame, verbose=False)
    probs = results[0].probs

    class_id = int(probs.top1)
    confidence = float(probs.top1conf)
    label = results[0].names[class_id]

    history.append(label)
    conf_history.append(confidence)

    if len(history) > 0:
        label_counts = Counter(history)
        stable_label, count = label_counts.most_common(1)[0]
        stable_conf = np.mean(conf_history)
    else:
        stable_label = "Detecting..."
        stable_conf = 0

    curr_time = time.time()
    fps = 1 / (curr_time - prev_time)
    prev_time = curr_time

    cv2.putText(
        frame,
        f"{stable_label} | percentage: {stable_conf:.2f}",
        (30, 50),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.8,
        (0, 255, 0),
        2
    )

    cv2.imshow("Model Input", input_frame)
    cv2.imshow("Posture Detector", frame)

    if cv2.waitKey(1) == 27:
        break

cap.release()
cv2.destroyAllWindows()
